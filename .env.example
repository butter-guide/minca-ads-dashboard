# Copie ce fichier en ".env" et remplis tes vraies valeurs.
# NE JAMAIS committer le fichier .env (il est ignoré par git).

# --- Meta / Facebook Ads ---
META_ACCESS_TOKEN=colle_ici_ton_token_system_user
META_AD_ACCOUNT_ID=act_1234567890
META_DATE_PRESET=last_30d

# --- Shopify (app Dev Dashboard) ---
SHOPIFY_STORE=mincaparis.myshopify.com
SHOPIFY_CLIENT_ID=xxxxxxxxxxxxxxxx
SHOPIFY_CLIENT_SECRET=xxxxxxxxxxxxxxxx

# --- Google Sheets (Apps Script Web App) ---
SHEETS_WEBAPP_URL=https://script.google.com/macros/s/xxxx/exec
SHEETS_SECRET=un_secret_au_choix

CURRENCY=EUR
